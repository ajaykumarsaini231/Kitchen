# Copy to .env and adjust as needed.

# MongoDB connection string.
# Local single-node replica set (see docker-compose.yml): keep the replicaSet param.
MONGODB_URI=mongodb+srv://ajaykumarsaini:<db_password>@cluster0.k8kqsto.mongodb.net/?appName=Cluster0

# If you use a standalone mongod (no replica set), use this instead — the server
# will automatically fall back to polling for real-time updates:
# MONGODB_URI=mongodb://127.0.0.1:27017/dishdb

# Port the API/WebSocket server listens on.
PORT=4000

# Comma-separated allowed CORS origins: Vite CMS (5173) + public Next.js site (3000).
CLIENT_ORIGIN=http://localhost:5173,http://localhost:3000

# Polling interval (ms) used only when change streams are unavailable.
POLL_INTERVAL_MS=2000

# --- Auth ---
# Secret used to sign JWTs. CHANGE THIS in production.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES=7d

# Seed accounts (created on startup if missing). Change before deploying.
ADMIN_EMAIL=admin@metnmat.com
ADMIN_PASSWORD=admin123
VIEWER_EMAIL=viewer@metnmat.com
VIEWER_PASSWORD=viewer123

# --- Logging ---
# pino level: trace|debug|info|warn|error|fatal|silent
LOG_LEVEL=info
