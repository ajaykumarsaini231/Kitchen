{
  "name": "dish-dashboard-server",
  "version": "1.0.0",
  "description": "Express + MongoDB + Socket.IO API for the dish dashboard",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build": "echo \"no build step needed for the API server\"",
    "dev": "node --watch src/index.js",
    "seed": "node src/seed.js",
    "toggle": "node src/toggleCli.js",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb-memory-server": "^10.1.2",
    "mongoose": "^8.5.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "socket.io": "^4.7.5",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}
